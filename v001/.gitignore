# CMake / Ninja build trees
build/
build-*/
**/build/

# Compiled objects and archives
*.o
*.a
*.so
*.dylib

# Module artifacts (GCC)
*.gcm
*.dd
*.ddi
*.modmap

# Executables (local smoke/test binaries)
*.out

# IDE / editor
.vscode/
.idea/
*.swp
*~

# OS
.DS_Store
Thumbs.db

# Local scratch (smoke monitor + ad-hoc helpers)
/.tmp_*

# Local matrix run artifacts — persist files stay ignored; .log text is committable
test-results/**
!test-results/**/
!test-results/**/*.log
!test-results/README.md
kept-logs/**
!kept-logs/**/
!kept-logs/**/*.log
!kept-logs/README.md

# Matrix persist spillover at repo root (cwd-relative test output)
/persist*

# Auto-generated, per-machine sensed-environment snapshot (informational only)
/FileCheckList.txt

# Machine-local compiler registry override
/compilers.local.conf

# Machine-local host label (anonymizes results: hostname() reads this instead of uname)
/host_label.local

# Generated, per-machine provisioning script + local recipe override
/Setup.sh
/recipes.local.conf

# Per-run handoff written by bootstrap.sh, read by the committed Setup/jac313_setup.
# (The jac313_setup binary itself IS tracked — no extension, no rule matches it.)
/Setup/.setup_handoff

# Convenience symlinks to the bootstrap-built tools (targets live in a gitignored build dir)
/jac313_test_cli
/jac313_wipe_all
/jac313_wipe_one
/jac313_wipe_jac

# Generated, re-runnable preset script (overwritten each preset invocation)
/run_latest_config.sh

# store_bench durable output at the v001 root (cwd-relative: bench.bin / .jtext / .sql / .db)
/bench*

# build-times gate's transient per-config trees (safe_rmdir'd after each, but ignore if interrupted)
/tmp_build/